<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>D Motion</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:#0a0a0a;color:#fff;font-family:'Inter',sans-serif;overflow-x:hidden}

/* ── EDIT MODE TOGGLE ── */
#edit-toggle{position:fixed;bottom:24px;left:24px;z-index:999;background:rgba(0,0,0,0.7);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.5);font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.2em;text-transform:uppercase;padding:10px 18px;cursor:pointer;backdrop-filter:blur(8px);transition:all 0.3s}
#edit-toggle:hover,#edit-toggle.active{border-color:#fff;color:#fff;background:rgba(255,255,255,0.1)}
#edit-toggle.active{color:#f0c040;border-color:#f0c040}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;padding:20px 32px;background:transparent;pointer-events:none;transition:background 0.4s,backdrop-filter 0.4s}
.nav-logo-wrap{pointer-events:all;position:relative}
#logo-img{height:48px;width:48px;object-fit:cover;display:block;cursor:pointer;border-radius:50%}
#logo-img:hover{opacity:0.8}
.logo-edit-hint{display:none;position:absolute;top:50px;left:0;background:rgba(0,0,0,0.85);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.6);font-size:10px;letter-spacing:0.1em;padding:6px 10px;white-space:nowrap;pointer-events:none}
body.editing .logo-edit-hint{display:block}
.nav-links{display:none}

/* ── HERO ── */
#hero{position:relative;width:100%;height:100vh;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center}
.hero-video-wrap{position:absolute;inset:0;z-index:0}
.hero-video-wrap iframe{width:100%;height:100%;border:none;pointer-events:none}
.hero-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.45);z-index:1;pointer-events:none}
.hero-content{position:relative;z-index:2;text-align:center;display:flex;flex-direction:column;align-items:center;pointer-events:none}
.hero-name{font-size:clamp(60px,10vw,120px);font-weight:900;letter-spacing:-0.02em;line-height:1;color:#fff;text-transform:uppercase}
.hero-tagline{font-size:14px;font-weight:300;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-top:16px}
.hero-nav{position:absolute;top:62%;left:50%;transform:translateX(-50%);z-index:10;display:flex;width:clamp(300px,48vw,580px);pointer-events:all}
.hero-nav a{flex:1;display:flex;align-items:center;justify-content:center;padding:20px 0;color:rgba(255,255,255,0.85);text-decoration:none;font-size:11px;letter-spacing:0.22em;text-transform:uppercase;background:rgba(80,90,80,0.35);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.15);transition:background 0.3s,color 0.3s;cursor:pointer}
.hero-nav a:not(:last-child){border-right:none}
.hero-nav a:hover{background:rgba(255,255,255,0.18);color:#fff}

/* edit-mode click hint on hero video */
.hero-edit-btn{display:none;position:absolute;bottom:20px;right:32px;z-index:4;background:rgba(0,0,0,0.6);border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.7);font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;padding:8px 16px;cursor:pointer;backdrop-filter:blur(8px)}
body.editing .hero-edit-btn{display:block}
.hero-edit-btn:hover{border-color:#fff;color:#fff}

/* ── SECTIONS ── */
section{padding:100px 48px}
.section-label{font-size:11px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:48px}

/* ── WORK ── */
#work{background:#0a0a0a}
.work-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.work-card{position:relative;aspect-ratio:16/9;overflow:hidden;cursor:pointer;background:#111}
.work-card .thumb{position:absolute;inset:0;background:#1a1a1a}
.work-card .thumb img{width:100%;height:100%;object-fit:cover;opacity:0.65}
.work-card-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.55);z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;transition:opacity 0.3s}
.work-card:hover .work-card-overlay{opacity:1}
.work-card-title{font-size:18px;font-weight:700;letter-spacing:0.04em;text-transform:uppercase;text-align:center}
.work-card-client{font-size:11px;letter-spacing:0.2em;color:rgba(255,255,255,0.5);margin-top:6px;text-transform:uppercase}
.wc-btns{display:flex;gap:8px;margin-top:14px}
.wc-btn{width:38px;height:38px;border:1px solid rgba(255,255,255,0.4);display:flex;align-items:center;justify-content:center;background:none;cursor:pointer;transition:all 0.3s}
.wc-btn:hover{background:rgba(255,255,255,0.15);border-color:#fff}
.wc-btn svg{width:15px;height:15px;stroke:#fff;fill:none;stroke-width:2}
/* edit pencil only in edit mode */
.wc-btn.edit-only{display:none}
body.editing .wc-btn.edit-only{display:flex}
/* add card btn */
.add-card-btn{display:none;align-items:center;justify-content:center;aspect-ratio:16/9;border:1px dashed rgba(255,255,255,0.15);cursor:pointer;background:transparent;color:rgba(255,255,255,0.3);flex-direction:column;gap:8px;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;width:100%;transition:all 0.3s}
body.editing .add-card-btn{display:flex}
.add-card-btn:hover{border-color:rgba(255,255,255,0.45);color:rgba(255,255,255,0.7)}
.add-card-btn svg{width:22px;height:22px;stroke:currentColor;fill:none;stroke-width:1.5}

/* ── VIDEO MODAL ── */
.vmodal{display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,0.93);align-items:center;justify-content:center}
.vmodal.open{display:flex}
.vmodal-inner{position:relative;width:90vw;max-width:1100px;aspect-ratio:16/9}
.vmodal-inner iframe{width:100%;height:100%;border:none}
.vmodal-close{position:absolute;top:-40px;right:0;background:none;border:none;color:#fff;font-size:24px;cursor:pointer;opacity:0.6}
.vmodal-close:hover{opacity:1}

/* ── PANELS ── */
.panel{display:none;position:fixed;inset:0;z-index:700;background:rgba(0,0,0,0.82);align-items:center;justify-content:center}
.panel.open{display:flex}
.panel-box{background:#111;border:1px solid rgba(255,255,255,0.15);padding:32px;width:500px;max-width:92vw;max-height:90vh;overflow-y:auto}
.panel-box h3{font-size:13px;letter-spacing:0.22em;text-transform:uppercase;margin-bottom:24px;font-weight:400;color:rgba(255,255,255,0.6)}
.pf{margin-bottom:16px}
.pf label{display:block;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:5px}
.pf input,.pf textarea{width:100%;background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.18);color:#fff;font-family:'Inter',sans-serif;font-size:13px;padding:6px 0;outline:none;resize:none}
.pf input:focus,.pf textarea:focus{border-bottom-color:rgba(255,255,255,0.6)}
.pf input::placeholder,.pf textarea::placeholder{color:rgba(255,255,255,0.18)}
.pbtn-row{display:flex;gap:8px;margin-top:24px;flex-wrap:wrap}
.pbtn{flex:1;min-width:80px;background:none;border:1px solid rgba(255,255,255,0.22);color:#fff;font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;padding:10px;cursor:pointer;transition:all 0.3s}
.pbtn:hover{background:rgba(255,255,255,0.08)}
.pbtn.primary{border-color:#fff}
.pbtn.danger{border-color:#c0392b;color:#c0392b}

/* file upload area */
.file-drop{border:1px dashed rgba(255,255,255,0.2);padding:16px;text-align:center;cursor:pointer;margin-top:8px;transition:border-color 0.3s}
.file-drop:hover{border-color:rgba(255,255,255,0.5)}
.file-drop span{font-size:11px;letter-spacing:0.1em;color:rgba(255,255,255,0.3)}

/* ── SHOWREEL ── */
#showreel{background:#0d0d0d;padding:80px 48px}
.showreel-title{font-size:clamp(40px,6vw,72px);font-weight:900;text-transform:uppercase;letter-spacing:-0.02em;margin-bottom:40px}
.showreel-embed{position:relative;aspect-ratio:16/9;background:#111;overflow:hidden}
.showreel-embed iframe{width:100%;height:100%;border:none}
.showreel-ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px}
.showreel-ph svg{width:56px;height:56px;stroke:rgba(255,255,255,0.15);fill:none;stroke-width:1}
.showreel-ph span{font-size:11px;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.18)}
.sr-edit-btn{display:none;margin-top:14px;background:none;border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.35);font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;padding:8px 16px;cursor:pointer;transition:all 0.3s}
body.editing .sr-edit-btn{display:inline-flex}
.sr-edit-btn:hover{border-color:#fff;color:#fff}

/* ── SERVICES ── */
#services{background:#0a0a0a;padding:80px 0}
.services-header{padding:0 48px 40px}
.services-slider-wrap{overflow:hidden;cursor:grab;user-select:none}
.services-track{display:flex;transition:transform 0.55s cubic-bezier(0.77,0,0.175,1)}
.service-slide{min-width:100%;display:grid;grid-template-columns:1fr 1fr;gap:2px}
.service-img-box{position:relative;aspect-ratio:4/3;overflow:hidden;background:#111}
.service-img-box img{width:100%;height:100%;object-fit:cover;opacity:0.8}
.service-img-ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px}
.service-img-ph svg{width:36px;height:36px;stroke:rgba(255,255,255,0.18);fill:none;stroke-width:1.5}
.service-img-ph span{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.18)}
.service-text-box{background:#111;padding:48px;display:flex;flex-direction:column;justify-content:center}
.service-text-box h3{font-size:26px;font-weight:700;text-transform:uppercase;letter-spacing:0.02em;margin-bottom:14px}
.service-text-box p{font-size:14px;line-height:1.75;color:rgba(255,255,255,0.58);margin-bottom:20px}
.service-text-box ul{list-style:none;display:flex;flex-direction:column;gap:7px}
.service-text-box li{font-size:12px;letter-spacing:0.07em;color:rgba(255,255,255,0.38);padding-left:16px;position:relative}
.service-text-box li::before{content:'—';position:absolute;left:0;color:rgba(255,255,255,0.18)}
.svc-edit-btn{display:none;margin-top:20px;background:none;border:1px solid rgba(255,255,255,0.18);color:rgba(255,255,255,0.4);font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.18em;text-transform:uppercase;padding:8px 16px;cursor:pointer;transition:all 0.3s;align-self:flex-start}
body.editing .svc-edit-btn{display:block}
.svc-edit-btn:hover{border-color:#fff;color:#fff}
.svc-nav-row{display:flex;gap:12px;padding:20px 48px 0;align-items:center}
.svc-arrow{background:none;border:1px solid rgba(255,255,255,0.2);color:#fff;width:42px;height:42px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.3s}
.svc-arrow:hover{border-color:#fff}
.svc-arrow svg{width:17px;height:17px;stroke:#fff;fill:none;stroke-width:2}
.svc-dots{display:flex;gap:8px;align-items:center}
.svc-dot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.2);cursor:pointer;transition:background 0.3s}
.svc-dot.active{background:#fff}
.svc-add-btn{display:none;margin-left:auto;background:none;border:1px dashed rgba(255,255,255,0.18);color:rgba(255,255,255,0.3);font-family:'Inter',sans-serif;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;padding:8px 16px;cursor:pointer;transition:all 0.3s}
body.editing .svc-add-btn{display:block}
.svc-add-btn:hover{border-color:rgba(255,255,255,0.5);color:rgba(255,255,255,0.7)}

/* ── FOOTER ── */
footer{padding:80px 48px 48px;border-top:1px solid rgba(255,255,255,0.06)}
.footer-cta{font-size:clamp(32px,5vw,56px);font-weight:900;text-transform:uppercase;letter-spacing:-0.01em;margin-bottom:40px}
.footer-cta span{color:rgba(255,255,255,0.2)}
.footer-contact a{color:#fff;text-decoration:none;font-size:14px;border-bottom:1px solid rgba(255,255,255,0.3);padding-bottom:2px;transition:border-color 0.3s}
.footer-contact a:hover{border-color:#fff}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;margin-top:56px;padding-top:24px;border-top:1px solid rgba(255,255,255,0.06)}
.footer-bottom p{font-size:11px;color:rgba(255,255,255,0.22);letter-spacing:0.05em}
.footer-socials{display:flex;gap:20px}
.footer-socials a{font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.28);text-decoration:none;transition:color 0.3s}
.footer-socials a:hover{color:#fff}

/* ── SCROLL HINT ── */
.scroll-hint{position:absolute;bottom:40px;right:40px;z-index:2;display:flex;flex-direction:column;align-items:center;gap:8px}
.scroll-hint span{font-size:9px;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.25);writing-mode:vertical-rl}
.scroll-line{width:1px;height:44px;background:rgba(255,255,255,0.12);position:relative;overflow:hidden}
.scroll-line::after{content:'';position:absolute;top:-100%;left:0;width:100%;height:100%;background:#fff;animation:sline 2.2s ease infinite}
@keyframes sline{0%{top:-100%}100%{top:100%}}

/* edit outline on hover in edit mode */
body.editing .work-card:hover,body.editing .service-img-box:hover,body.editing .showreel-embed:hover{outline:1px dashed rgba(240,192,64,0.5)}

@media(max-width:860px){
  .work-grid{grid-template-columns:repeat(2,1fr)}
  .service-slide{grid-template-columns:1fr}
  .service-img-box{aspect-ratio:16/9}
  .service-text-box{padding:28px 24px}
  section{padding:70px 24px}
  .services-header,.svc-nav-row{padding-left:24px;padding-right:24px}
  footer{padding:60px 24px 40px}
}
</style>
</head>
<body>

<!-- EDIT TOGGLE -->
<button id="edit-toggle" onclick="toggleEditMode()">✏ Edit mode</button>

<!-- NAV -->
<nav id="main-nav">
  <div class="nav-logo-wrap">
    <img id="logo-img" src="data:image/jpeg;base64," alt="D Motion" onclick="editLogo()" title="Click to change logo">
    <div class="logo-edit-hint">Click to change logo</div>
    <input type="file" id="logo-file" accept="image/*" style="display:none" onchange="applyLogoFile(this)">
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-video-wrap" id="hero-video-wrap">
    <div id="hero-ph" style="position:absolute;inset:0;background:#060606;display:flex;align-items:center;justify-content:center">
      <span style="font-size:10px;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.1)">Hero video</span>
    </div>
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-name">D Motion</div>
    <div class="hero-tagline">Aerial Cinematography</div>
  </div>
  <nav class="hero-nav">
    <a href="#work" onclick="smoothTo('work',event)">Work</a>
    <a href="#showreel" onclick="smoothTo('showreel',event)">Showreel</a>
    <a href="#services" onclick="smoothTo('services',event)">Services</a>
  </nav>
  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
  <button class="hero-edit-btn" onclick="openHeroPanel()">Change video</button>
</section>

<!-- WORK -->
<section id="work">
  <div class="section-label">Work</div>
  <div class="work-grid" id="work-grid"></div>
  <button class="add-card-btn" id="add-card-btn" onclick="openCardPanel(null)">
    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Add a project
  </button>
</section>

<!-- SHOWREEL -->
<section id="showreel">
  <div class="showreel-title">Showreel</div>
  <div class="showreel-embed" id="showreel-embed">
    <div class="showreel-ph">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="10,8 16,12 10,16" fill="rgba(255,255,255,0.1)"/></svg>
      <span>Add your showreel</span>
    </div>
  </div>
  <button class="sr-edit-btn" onclick="openSRPanel()">✏ Change video showreel</button>
</section>

<!-- SERVICES -->
<section id="services" style="padding:80px 0">
  <div class="services-header">
    <div class="section-label">Services</div>
  </div>
  <div class="services-slider-wrap" id="svc-wrap">
    <div class="services-track" id="svc-track"></div>
  </div>
  <div class="svc-nav-row">
    <button class="svc-arrow" onclick="slideSvc(-1)"><svg viewBox="0 0 24 24"><polyline points="15,18 9,12 15,6"/></svg></button>
    <div class="svc-dots" id="svc-dots"></div>
    <button class="svc-arrow" onclick="slideSvc(1)"><svg viewBox="0 0 24 24"><polyline points="9,18 15,12 9,6"/></svg></button>
    <button class="svc-add-btn" onclick="openSvcPanel(null)">+ Add a service</button>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-cta">Let's work<br><span>together</span></div>
  <div class="footer-contact"><a href="mailto:needdmotion@gmail.com">needdmotion@gmail.com</a></div>
  <div class="footer-bottom">
    <p>© 2025 D Motion. All rights reserved.</p>
    <div class="footer-socials"><a href="https://www.instagram.com/dmot1on/?hl=fr" target="_blank">Instagram</a><a href="https://www.youtube.com/@dmot1on" target="_blank">YouTube</a></div>
  </div>
</footer>

<!-- VIDEO MODAL -->
<div class="vmodal" id="vmodal">
  <div class="vmodal-inner" id="vmodal-inner">
    <button class="vmodal-close" onclick="closeVModal()">✕</button>
  </div>
</div>

<!-- PANEL: Hero video -->
<div class="panel" id="p-hero">
  <div class="panel-box">
    <h3>Hero Video (background)</h3>
    <div class="pf"><label>YouTube or Vimeo URL</label><input type="text" id="hero-url-in" placeholder="https://www.youtube.com/watch?v=..."></div>
    <div class="pf">
      <label>OR upload a video (MP4, MOV…)</label>
      <div class="file-drop" onclick="document.getElementById('hero-vid-file').click()">
        <span id="hero-vid-hint">Click to choose a video</span>
      </div>
      <input type="file" id="hero-vid-file" accept="video/*" style="display:none" onchange="applyHeroFile(this)">
    </div>
    <div class="pbtn-row">
      <button class="pbtn" onclick="closePanel('p-hero')">Cancel</button>
      <button class="pbtn primary" onclick="applyHeroVideo()">Apply URL</button>
    </div>
  </div>
</div>

<!-- PANEL: Work card -->
<div class="panel" id="p-card">
  <div class="panel-box">
    <h3 id="p-card-title">Add a project</h3>
    <div class="pf"><label>Titre</label><input type="text" id="c-title" placeholder="Project name"></div>
    <div class="pf"><label>Client</label><input type="text" id="c-client" placeholder="Brand / Client"></div>
    <div class="pf"><label>YouTube / Vimeo URL (optional if uploading)</label><input type="text" id="c-url" placeholder="https://www.youtube.com/watch?v=..."></div>
    <div class="pf">
      <label>OR upload a video (MP4, MOV…)</label>
      <div class="file-drop" onclick="document.getElementById('c-vid-file').click()">
        <span id="c-vid-hint">Click to choose a video</span>
      </div>
      <input type="file" id="c-vid-file" accept="video/*" style="display:none" onchange="previewCardVideo(this)">
      <input type="hidden" id="c-vid-b64">
    </div>
    <div class="pf">
      <label>Thumbnail image (optional)</label>
      <div class="file-drop" onclick="document.getElementById('c-thumb-file').click()">
        <span id="c-thumb-hint">Click to choose an image</span>
      </div>
      <input type="file" id="c-thumb-file" accept="image/*" style="display:none" onchange="previewThumb(this)">
      <input type="hidden" id="c-thumb-b64">
    </div>
    <div class="pbtn-row">
      <button class="pbtn" onclick="closePanel('p-card')">Cancel</button>
      <button class="pbtn danger" id="c-del-btn" onclick="deleteCard()">Delete</button>
      <button class="pbtn primary" onclick="saveCard()">Save</button>
    </div>
  </div>
</div>

<!-- PANEL: Showreel -->
<div class="panel" id="p-sr">
  <div class="panel-box">
    <h3>Showreel</h3>
    <div class="pf"><label>YouTube or Vimeo URL</label><input type="text" id="sr-url-in" placeholder="https://..."></div>
    <div class="pbtn-row">
      <button class="pbtn" onclick="closePanel('p-sr')">Cancel</button>
      <button class="pbtn primary" onclick="applySR()">Apply & Save</button>
    </div>
  </div>
</div>

<!-- PANEL: Service -->
<div class="panel" id="p-svc">
  <div class="panel-box">
    <h3 id="p-svc-title">Add a service</h3>
    <div class="pf"><label>Titre</label><input type="text" id="s-title" placeholder="Ex: FPV Drone"></div>
    <div class="pf"><label>Description</label><textarea id="s-desc" rows="3" placeholder="Description..."></textarea></div>
    <div class="pf"><label>Key points (comma separated)</label><input type="text" id="s-points" placeholder="Cinéma, Commercial, Live event"></div>
    <div class="pf">
      <label>Image</label>
      <div class="file-drop" onclick="document.getElementById('s-img-file').click()">
        <span id="s-img-hint">Click to choose an image</span>
      </div>
      <input type="file" id="s-img-file" accept="image/*" style="display:none" onchange="previewSvcImg(this)">
      <input type="hidden" id="s-img-b64">
    </div>
    <div class="pbtn-row">
      <button class="pbtn" onclick="closePanel('p-svc')">Cancel</button>
      <button class="pbtn danger" id="s-del-btn" onclick="deleteService()">Delete</button>
      <button class="pbtn primary" onclick="saveService()">Save</button>
    </div>
  </div>
</div>

<script>
// ── STORAGE ──────────────────────────────────────────────────────────────────
const DB = {
  get(k,def){try{const v=localStorage.getItem('dm_'+k);return v!==null?JSON.parse(v):def}catch{return def}},
  set(k,v){try{localStorage.setItem('dm_'+k,JSON.stringify(v))}catch(e){console.warn('Storage full',e)}}
};

// ── STATE ─────────────────────────────────────────────────────────────────────
let editMode = false;
let cards = DB.get('cards',[
  {id:1,title:'Hawaii FPV',client:'Personal',url:'',thumb:''},
  {id:2,title:'Showreel 2024',client:'D Motion',url:'',thumb:''},
  {id:3,title:'Commercial Project',client:'Brand',url:'',thumb:''}
]);
let services = DB.get('services',[
  {id:1,title:'Drone FPV',desc:'High-speed immersive shots for cinematic and commercial productions.',points:['Cinema & Advertising','Racing & Sport','Confined spaces'],img:''},
  {id:2,title:'Aerial Cinema',desc:'Stabilized aerial sequences for all types of productions.',points:['Films & Series','Events','Landscape'],img:''}
]);
let srUrl = DB.get('srUrl','');
let heroUrl = DB.get('heroUrl','');
let logoSrc = DB.get('logoSrc','data:image/jpeg;base64,');
let svcIdx = 0;
let editingCard = null;
let editingSvc = null;

// ── INIT LOGO ─────────────────────────────────────────────────────────────────
document.getElementById('logo-img').src = logoSrc;

// ── EDIT MODE ─────────────────────────────────────────────────────────────────
function toggleEditMode(){
  editMode=!editMode;
  document.body.classList.toggle('editing',editMode);
  const btn=document.getElementById('edit-toggle');
  btn.classList.toggle('active',editMode);
  btn.textContent=editMode?'✓ Exit edit mode':'✏ Edit mode';
}

// ── LOGO ─────────────────────────────────────────────────────────────────────
function editLogo(){
  if(!editMode) return;
  document.getElementById('logo-file').click();
}
function applyLogoFile(input){
  const file=input.files[0]; if(!file) return;
  const r=new FileReader();
  r.onload=ev=>{
    logoSrc=ev.target.result;
    document.getElementById('logo-img').src=logoSrc;
    DB.set('logoSrc',logoSrc);
  };
  r.readAsDataURL(file);
}

// ── UTILS ─────────────────────────────────────────────────────────────────────
function embedUrl(url,autoplay=true){
  if(!url) return '';
  const yt=url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
  if(yt) return `https://www.youtube.com/embed/${yt[1]}?autoplay=${autoplay?1:0}&mute=1&loop=1&playlist=${yt[1]}&controls=${autoplay?0:1}&showinfo=0`;
  const vi=url.match(/vimeo\.com\/(\d+)/);
  if(vi) return `https://player.vimeo.com/video/${vi[1]}?autoplay=${autoplay?1:0}&muted=1&loop=1&background=${autoplay?1:0}`;
  return url;
}
function ytThumb(url){
  const yt=url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
  return yt?`https://img.youtube.com/vi/${yt[1]}/maxresdefault.jpg`:'';
}

// ── HERO VIDEO ────────────────────────────────────────────────────────────────
function openHeroPanel(){
  document.getElementById('hero-url-in').value=heroUrl;
  openPanel('p-hero');
}
function applyHeroVideo(){
  heroUrl=document.getElementById('hero-url-in').value.trim();
  DB.set('heroUrl',heroUrl);
  DB.set('heroFileB64','');
  renderHero();
  closePanel('p-hero');
}
function applyHeroFile(input){
  const file=input.files[0]; if(!file) return;
  document.getElementById('hero-vid-hint').textContent='Loading…';
  const r=new FileReader();
  r.onload=ev=>{
    const b64=ev.target.result;
    DB.set('heroFileB64',b64);
    DB.set('heroUrl','');
    heroUrl='';
    renderHeroFile(b64);
    document.getElementById('hero-vid-hint').textContent='Video selected ✓';
    closePanel('p-hero');
  };
  r.readAsDataURL(file);
}
function renderHeroFile(b64){
  const wrap=document.getElementById('hero-video-wrap');
  const ph=document.getElementById('hero-ph');
  if(ph) ph.style.display='none';
  wrap.querySelectorAll('iframe,video').forEach(el=>el.remove());
  wrap.insertAdjacentHTML('beforeend',`<video src="${b64}" autoplay muted loop playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none"></video>`);
}
function renderHero(){
  const heroFileB64=DB.get('heroFileB64','');
  if(heroFileB64){ renderHeroFile(heroFileB64); return; }
  const wrap=document.getElementById('hero-video-wrap');
  if(heroUrl){
    const ph=document.getElementById('hero-ph');
    if(ph) ph.style.display='none';
    wrap.querySelectorAll('iframe,video').forEach(el=>el.remove());
    const e=embedUrl(heroUrl,true);
    wrap.insertAdjacentHTML('beforeend',`<iframe src="${e}" frameborder="0" allow="autoplay;fullscreen" allowfullscreen style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none"></iframe>`);
  }
}

// ── WORK GRID ─────────────────────────────────────────────────────────────────
function renderWork(){
  const g=document.getElementById('work-grid');
  g.innerHTML='';
  cards.forEach(c=>{
    const thumb=c.thumb||(c.url?ytThumb(c.url):'');
    const d=document.createElement('div');
    d.className='work-card';
    d.innerHTML=`
      <div class="thumb">${thumb?`<img src="${thumb}" alt="${c.title}">`:'<div style="position:absolute;inset:0;background:linear-gradient(135deg,#1c1c1c,#0d0d0d)"></div>'}</div>
      <div class="work-card-overlay">
        <div class="work-card-title">${c.title}</div>
        <div class="work-card-client">${c.client}</div>
        <div class="wc-btns">
          ${c.url?`<button class="wc-btn" onclick="event.stopPropagation();playVideo('${c.url}')"><svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21" fill="white" stroke="none"/></svg></button>`:''}
          <button class="wc-btn edit-only" onclick="event.stopPropagation();openCardPanel(${c.id})"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg></button>
        </div>
      </div>`;
    if(c.url) d.addEventListener('click',()=>playVideo(c.url));
    g.appendChild(d);
  });
}

function openCardPanel(id){
  editingCard=id;
  const c=id?cards.find(x=>x.id===id):null;
  document.getElementById('p-card-title').textContent=c?'Edit project':'Add a project';
  document.getElementById('c-title').value=c?c.title:'';
  document.getElementById('c-client').value=c?c.client:'';
  document.getElementById('c-url').value=c?c.url:'';
  document.getElementById('c-thumb-b64').value=c?c.thumb:'';
  document.getElementById('c-thumb-hint').textContent=c&&c.thumb?'Image selected ✓':'Click to choose an image';
  document.getElementById('c-vid-b64').value='';
  document.getElementById('c-vid-hint').textContent=c&&c.vidB64?'Existing video (upload to replace)':'Click to choose a video';
  document.getElementById('c-del-btn').style.display=c?'':'none';
  openPanel('p-card');
}
function previewCardVideo(input){
  const file=input.files[0]; if(!file) return;
  document.getElementById('c-vid-hint').textContent='Loading…';
  const r=new FileReader();
  r.onload=ev=>{
    document.getElementById('c-vid-b64').value=ev.target.result;
    document.getElementById('c-vid-hint').textContent='Video selected ✓';
  };
  r.readAsDataURL(file);
}
function previewThumb(input){
  const file=input.files[0]; if(!file) return;
  const r=new FileReader();
  r.onload=ev=>{document.getElementById('c-thumb-b64').value=ev.target.result;document.getElementById('c-thumb-hint').textContent='Image selected ✓';};
  r.readAsDataURL(file);
}
function saveCard(){
  const title=document.getElementById('c-title').value.trim()||'Untitled';
  const client=document.getElementById('c-client').value.trim();
  const url=document.getElementById('c-url').value.trim();
  const thumb=document.getElementById('c-thumb-b64').value;
  const vidB64=document.getElementById('c-vid-b64').value;
  if(editingCard){
    const c=cards.find(x=>x.id===editingCard);
    if(c){c.title=title;c.client=client;c.url=url;if(thumb)c.thumb=thumb;if(vidB64)c.vidB64=vidB64;}
  } else {
    cards.push({id:Date.now(),title,client,url,thumb,vidB64});
  }
  DB.set('cards',cards);
  closePanel('p-card');
  renderWork();
}
function deleteCard(){
  if(editingCard) cards=cards.filter(x=>x.id!==editingCard);
  DB.set('cards',cards);
  closePanel('p-card');
  renderWork();
}

// ── VIDEO MODAL ───────────────────────────────────────────────────────────────
function playVideo(url,b64){
  let content;
  if(b64){
    content=`<video src="${b64}" controls autoplay style="width:100%;height:100%;background:#000"></video>`;
  } else {
    const e=embedUrl(url,false);
    content=`<iframe src="${e}" frameborder="0" allow="autoplay;fullscreen" allowfullscreen style="width:100%;height:100%;border:none"></iframe>`;
  }
  document.getElementById('vmodal-inner').innerHTML=`<button class="vmodal-close" onclick="closeVModal()">✕</button>${content}`;
  document.getElementById('vmodal').classList.add('open');
}
function closeVModal(){
  document.getElementById('vmodal-inner').innerHTML='<button class="vmodal-close" onclick="closeVModal()">✕</button>';
  document.getElementById('vmodal').classList.remove('open');
}
document.getElementById('vmodal').addEventListener('click',function(e){if(e.target===this)closeVModal();});

// ── SHOWREEL ──────────────────────────────────────────────────────────────────
function openSRPanel(){document.getElementById('sr-url-in').value=srUrl;openPanel('p-sr');}
function applySR(){
  srUrl=document.getElementById('sr-url-in').value.trim();
  DB.set('srUrl',srUrl);
  renderSR();
  closePanel('p-sr');
}
function renderSR(){
  const el=document.getElementById('showreel-embed');
  if(srUrl){
    const e=embedUrl(srUrl,false).replace('mute=1','').replace('background=1','').replace('controls=0','controls=1');
    el.innerHTML=`<iframe src="${e}" frameborder="0" allow="autoplay;fullscreen" allowfullscreen style="width:100%;height:100%;border:none"></iframe>`;
  } else {
    el.innerHTML=`<div class="showreel-ph"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="10,8 16,12 10,16" fill="rgba(255,255,255,0.1)"/></svg><span>Add your showreel</span></div>`;
    el.querySelector('.showreel-ph').addEventListener('click',()=>{if(editMode)openSRPanel();});
  }
}

// ── SERVICES ─────────────────────────────────────────────────────────────────
function renderServices(){
  const track=document.getElementById('svc-track');
  const dots=document.getElementById('svc-dots');
  track.innerHTML='';dots.innerHTML='';
  services.forEach((s,i)=>{
    const slide=document.createElement('div');
    slide.className='service-slide';
    slide.innerHTML=`
      <div class="service-img-box">
        ${s.img?`<img src="${s.img}" alt="${s.title}">`:`<div class="service-img-ph"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg><span>Ajouter une image</span></div>`}
      </div>
      <div class="service-text-box">
        <h3>${s.title}</h3>
        <p>${s.desc}</p>
        <ul>${s.points.map(p=>`<li>${p}</li>`).join('')}</ul>
        <button class="svc-edit-btn" onclick="openSvcPanel(${s.id})">✏ Edit this service</button>
      </div>`;
    track.appendChild(slide);
    const dot=document.createElement('div');
    dot.className='svc-dot'+(i===svcIdx?' active':'');
    dot.onclick=()=>{svcIdx=i;updateSvcPos();};
    dots.appendChild(dot);
  });
  updateSvcPos();
}
function updateSvcPos(){
  document.getElementById('svc-track').style.transform=`translateX(-${svcIdx*100}%)`;
  document.querySelectorAll('.svc-dot').forEach((d,i)=>d.classList.toggle('active',i===svcIdx));
}
function slideSvc(dir){svcIdx=Math.max(0,Math.min(services.length-1,svcIdx+dir));updateSvcPos();}

// Touch/drag swipe for services — works on iPad, trackpad, mouse
(()=>{
  let sx=0,sy=0,drag=false,moved=false,isHoriz=null;
  function getX(e){return e.touches?e.touches[0].clientX:e.clientX;}
  function getY(e){return e.touches?e.touches[0].clientY:e.clientY;}
  function onStart(e){
    sx=getX(e);sy=getY(e);drag=true;moved=false;isHoriz=null;
    document.getElementById('svc-track').style.transition='none';
  }
  function onMove(e){
    if(!drag) return;
    const dx=getX(e)-sx, dy=getY(e)-sy;
    if(isHoriz===null && (Math.abs(dx)>8||Math.abs(dy)>8)){
      isHoriz=Math.abs(dx)>Math.abs(dy);
    }
    if(!isHoriz) return;
    if(Math.abs(dx)>6) moved=true;
    if(e.cancelable) e.preventDefault();
    document.getElementById('svc-track').style.transform=`translateX(calc(-${svcIdx*100}% + ${dx}px))`;
  }
  function onEnd(e){
    if(!drag) return; drag=false;
    document.getElementById('svc-track').style.transition='transform 0.55s cubic-bezier(0.77,0,0.175,1)';
    if(!isHoriz){updateSvcPos();return;}
    const dx=(e.changedTouches?e.changedTouches[0].clientX:e.clientX)-sx;
    if(moved&&Math.abs(dx)>40){if(dx<0)slideSvc(1);else slideSvc(-1);}
    else updateSvcPos();
  }
  window.addEventListener('DOMContentLoaded',()=>{
    const wr=document.getElementById('svc-wrap');
    wr.style.cursor='grab';
    wr.addEventListener('mousedown',onStart);
    wr.addEventListener('touchstart',onStart,{passive:true});
    window.addEventListener('mousemove',onMove);
    window.addEventListener('touchmove',onMove,{passive:false});
    window.addEventListener('mouseup',onEnd);
    window.addEventListener('touchend',onEnd);
    // trackpad two-finger horizontal scroll
    wr.addEventListener('wheel',(e)=>{
      if(Math.abs(e.deltaX)>Math.abs(e.deltaY)){
        e.preventDefault();
        if(e.deltaX>40) slideSvc(1);
        else if(e.deltaX<-40) slideSvc(-1);
      }
    },{passive:false});
  });
})();

function openSvcPanel(id){
  editingSvc=id;
  const s=id?services.find(x=>x.id===id):null;
  document.getElementById('p-svc-title').textContent=s?'Edit service':'Add a service';
  document.getElementById('s-title').value=s?s.title:'';
  document.getElementById('s-desc').value=s?s.desc:'';
  document.getElementById('s-points').value=s?s.points.join(', '):'';
  document.getElementById('s-img-b64').value=s?s.img:'';
  document.getElementById('s-img-hint').textContent=s&&s.img?'Image selected ✓':'Click to choose an image';
  document.getElementById('s-del-btn').style.display=s?'':'none';
  openPanel('p-svc');
}
function previewSvcImg(input){
  const file=input.files[0];if(!file)return;
  const r=new FileReader();
  r.onload=ev=>{document.getElementById('s-img-b64').value=ev.target.result;document.getElementById('s-img-hint').textContent='Image selected ✓';};
  r.readAsDataURL(file);
}
function saveService(){
  const title=document.getElementById('s-title').value.trim()||'Service';
  const desc=document.getElementById('s-desc').value.trim();
  const points=document.getElementById('s-points').value.split(',').map(x=>x.trim()).filter(Boolean);
  const img=document.getElementById('s-img-b64').value;
  if(editingSvc){
    const s=services.find(x=>x.id===editingSvc);
    if(s){s.title=title;s.desc=desc;s.points=points;if(img)s.img=img;}
  } else {
    services.push({id:Date.now(),title,desc,points,img});
  }
  DB.set('services',services);
  closePanel('p-svc');
  renderServices();
}
function deleteService(){
  if(editingSvc) services=services.filter(x=>x.id!==editingSvc);
  if(svcIdx>=services.length) svcIdx=Math.max(0,services.length-1);
  DB.set('services',services);
  closePanel('p-svc');
  renderServices();
}

// ── PANELS ───────────────────────────────────────────────────────────────────
function openPanel(id){document.getElementById(id).classList.add('open');}
function closePanel(id){document.getElementById(id).classList.remove('open');}
['p-hero','p-card','p-sr','p-svc'].forEach(id=>{
  document.getElementById(id).addEventListener('click',function(e){if(e.target===this)closePanel(id);});
});

// ── NAV SCROLL ────────────────────────────────────────────────────────────────
window.addEventListener('scroll',()=>{
  const nav=document.getElementById('main-nav');
  if(window.scrollY>60){nav.style.background='rgba(8,8,8,0.88)';nav.style.backdropFilter='blur(12px)';}
  else{nav.style.background='transparent';nav.style.backdropFilter='none';}
});

// ── SMOOTH SCROLL ─────────────────────────────────────────────────────────────
function smoothTo(id, e){
  if(e) e.preventDefault();
  const target = document.getElementById(id);
  if(!target) return;
  const start = window.scrollY;
  const end = target.getBoundingClientRect().top + window.scrollY;
  const duration = 900;
  let startTime = null;
  function ease(t){ return t<0.5 ? 4*t*t*t : 1-Math.pow(-2*t+2,3)/2; }
  function step(now){
    if(!startTime) startTime=now;
    const elapsed = now - startTime;
    const progress = Math.min(elapsed/duration, 1);
    window.scrollTo(0, start + (end-start)*ease(progress));
    if(progress < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

// ── BOOT ─────────────────────────────────────────────────────────────────────
renderHero();
renderWork();
renderSR();
renderServices();
</script>
</body>
